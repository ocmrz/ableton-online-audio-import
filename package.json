{
  "name": "online-audio-import",
  "private": true,
  "version": "0.2.0",
  "description": "Search and import online audio into Ableton Live",
  "license": "MIT",
  "author": "",
  "type": "module",
  "main": "dist/extension.js",
  "scripts": {
    "build": "tsc --noEmit && tsx build.ts --production",
    "build:dev": "tsc --noEmit && tsx build.ts",
    "start": "tsx build.ts && extensions-cli run --temp-directory ./.tmp --storage-directory ./.tmp/storage",
    "package": "npm run build && extensions-cli package",
    "test": "tsx --test src/**/*.test.ts"
  },
  "dependencies": {
    "@ableton-extensions/sdk": "file:./vendor/ableton-extensions-sdk-1.0.0-beta.0.tgz"
  },
  "devDependencies": {
    "@ableton-extensions/cli": "file:./vendor/ableton-extensions-cli-1.0.0-beta.0.tgz",
    "@types/node": "^25.2.3",
    "esbuild": "0.28.0",
    "tsx": "^4.19.0",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=22"
  }
}
